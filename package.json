{
  "name": "@usex/nest-shield",
  "version": "0.0.0",
  "description": "Enterprise-grade overload protection and traffic management for NestJS applications with distributed rate limiting, circuit breakers, and comprehensive monitoring",
  "license": "MIT",
  "url": "https://github.com/ali-master/nest-shield#readme",
  "keywords": [
    "nestjs",
    "overload-protection",
    "rate-limiting",
    "circuit-breaker",
    "load-shedding",
    "traffic-management",
    "ddos-protection",
    "api-protection",
    "distributed-systems",
    "redis",
    "monitoring",
    "scalability",
    "performance",
    "resilience",
    "fault-tolerance",
    "anomaly-detection",
    "adaptive-throttling",
    "request-queue",
    "typescript",
    "express",
    "fastify"
  ],
  "scripts": {
    "prebuild": "bunx rimraf dist",
    "build": "tsc -p tsconfig.build.json",
    "test": "jest",
    "test:unit": "jest --config ./test/jest-unit.json",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "format": "prettier --write \"**/*.ts\"",
    "format:check": "prettier --check \"**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "bun run lint --fix",
    "typecheck": "tsc --noEmit",
    "prepublish:next": "bun run build",
    "publish:next": "bun publish --access public --tag next",
    "prepublish:npm": "bun run build",
    "publish:npm": "bun publish --access public",
    "prerelease": "bun run build",
    "release": "release-it",
    "prepare": "simple-git-hooks install",
    "preinstall": "npx is-ci || npx only-allow bun"
  },
  "dependencies": {
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/platform-fastify": "^11.1.27",
    "ioredis": "^5.11.1",
    "memjs": "^1.3.2",
    "node-cache": "^5.1.2",
    "opossum": "^9.0.0",
    "uuid": "^14.0.0"
  },
  "optionalDependencies": {
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/websockets": "^11.1.27",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "9.0.0",
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-angular": "21.0.2",
    "@nestjs/common": "11.1.27",
    "@nestjs/core": "11.1.27",
    "@nestjs/testing": "11.1.27",
    "@types/express": "^5.0.6",
    "@types/jest": "30.0.0",
    "@types/memjs": "^1.3.3",
    "@types/node": "25.9.3",
    "@types/uuid": "^11.0.0",
    "eslint": "10.5.0",
    "eslint-plugin-format": "^2.0.1",
    "fastify": "^5.8.5",
    "globals": "17.6.0",
    "jest": "30.4.2",
    "lint-staged": "17.0.7",
    "prettier": "3.8.4",
    "reflect-metadata": "0.2.2",
    "release-it": "20.2.0",
    "rxjs": "7.8.2",
    "simple-git-hooks": "2.13.1",
    "ts-jest": "29.4.11",
    "typescript": "6.0.3"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "require": "./dist/core/index.js",
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./decorators": {
      "require": "./dist/decorators/index.js",
      "import": "./dist/decorators/index.js",
      "types": "./dist/decorators/index.d.ts"
    },
    "./services": {
      "require": "./dist/services/index.js",
      "import": "./dist/services/index.js",
      "types": "./dist/services/index.d.ts"
    },
    "./metrics": {
      "require": "./dist/metrics/index.js",
      "import": "./dist/metrics/index.js",
      "types": "./dist/metrics/index.d.ts"
    },
    "./metrics/aggregators": {
      "require": "./dist/metrics/aggregators/index.js",
      "import": "./dist/metrics/aggregators/index.js",
      "types": "./dist/metrics/aggregators/index.d.ts"
    },
    "./anomaly-detection": {
      "require": "./dist/anomaly-detection/index.js",
      "import": "./dist/anomaly-detection/index.js",
      "types": "./dist/anomaly-detection/index.d.ts"
    },
    "./storage": {
      "require": "./dist/storage/index.js",
      "import": "./dist/storage/index.js",
      "types": "./dist/storage/index.d.ts"
    },
    "./interfaces": {
      "require": "./dist/interfaces/index.js",
      "import": "./dist/interfaces/index.js",
      "types": "./dist/interfaces/index.d.ts"
    },
    "./adapters": {
      "require": "./dist/adapters/index.js",
      "import": "./dist/adapters/index.js",
      "types": "./dist/adapters/index.d.ts"
    },
    "./interceptors": {
      "require": "./dist/interceptors/index.js",
      "import": "./dist/interceptors/index.js",
      "types": "./dist/interceptors/index.d.ts"
    },
    "./guards": {
      "require": "./dist/guards/shield.guard.js",
      "import": "./dist/guards/shield.guard.js",
      "types": "./dist/guards/shield.guard.d.ts"
    },
    "./monitoring": {
      "require": "./dist/modules/monitoring.module.js",
      "import": "./dist/modules/monitoring.module.js",
      "types": "./dist/modules/monitoring.module.d.ts"
    }
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.2.0"
  },
  "lint-staged": {
    "*.{js,ts,mjs,cjs,json,.*rc}": [
      "bun eslint --fix"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ali-master/nest-shield"
  },
  "changelog": {
    "labels": {
      "feature": "Features",
      "bug": "Bug fixes",
      "enhancement": "Enhancements",
      "docs": "Docs",
      "dependencies": "Dependencies",
      "type: code style": "Code style tweaks",
      "status: blocked": "Breaking changes",
      "breaking change": "Breaking changes"
    }
  },
  "packageManager": "bun@1.3.14",
  "publishConfig": {
    "access": "public"
  }
}
