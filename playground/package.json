{
  "name": "nest-shield-playground",
  "version": "1.0.0",
  "description": "Comprehensive playground for testing NestShield protection features",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "typecheck": "tsc --noEmit",
    "test:knip": "knip",
    "test:knip:fix": "knip --fix",
    "format:check": "prettier --check \"**/*.{ts,tsx,mdx}\"",
    "format": "prettier --write \"**/*.{ts,tsx,mdx}\"",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "bun run lint --fix"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/platform-socket.io": "^11.1.27",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/websockets": "^11.1.27",
    "@usex/nest-shield": "file:../",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.41",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "prettier": "^3.8.4",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.6.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  }
}
